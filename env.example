# =============================================================================
# UERIS — Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
#   cp .env.example .env
#
# =============================================================================


# -----------------------------------------------------------------------------
# STREAMING MODE
# 'simulation' : file-based (default, works without Kafka)
# 'kafka'      : enterprise Kafka pipeline
# -----------------------------------------------------------------------------
STREAMING_MODE=simulation


# -----------------------------------------------------------------------------
# MONGODB
# Local:  mongodb://localhost:27017/
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
# Docker: mongodb://mongodb:27017/
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/
DB_NAME=urban_env_db


# -----------------------------------------------------------------------------
# KAFKA (only needed when STREAMING_MODE=kafka)
# Local Docker: kafka:9092 (inside Docker), localhost:29092 (from host)
# Cloud (Confluent/MSK): your-broker.cloud.confluent.io:9092
# -----------------------------------------------------------------------------
KAFKA_BROKER=localhost:29092
KAFKA_TOPIC=ueris.env.readings
KAFKA_DLQ_TOPIC=ueris.env.dlq
KAFKA_CONSUMER_GROUP=ueris-speed-layer
KAFKA_AUTO_OFFSET=latest

# Kafka security (leave as PLAINTEXT for local development)
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Kafka producer tuning
KAFKA_PRODUCER_RETRIES=5
KAFKA_REQUEST_TIMEOUT=30000
KAFKA_DELIVERY_TIMEOUT=120000
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10
KAFKA_ACKS=all


# -----------------------------------------------------------------------------
# LIVE DATA APIs
# -----------------------------------------------------------------------------
# WAQI (World Air Quality Index) - free at https://aqicn.org/api/
# Set to 'demo' to use Open-Meteo AQ fallback (no registration needed)
WAQI_TOKEN=demo

# Fetch interval in seconds (default: 60 = 1 reading per city per minute)
FETCH_INTERVAL_SECONDS=60


# -----------------------------------------------------------------------------
# FLASK SERVING LAYER
# -----------------------------------------------------------------------------
PORT=5000

# How long before a realtime reading is considered stale (minutes)
FRESHNESS_WINDOW_MIN=30

# How often the background LiveWorker fetches data on Render (seconds)
LIVE_FETCH_INTERVAL=60


# -----------------------------------------------------------------------------
# SPARK STRUCTURED STREAMING (kafka mode)
# -----------------------------------------------------------------------------
SPARK_TRIGGER_INTERVAL_S=10
CHECKPOINT_DIR=data/checkpoint_kafka


# -----------------------------------------------------------------------------
# DEAD LETTER QUEUE
# -----------------------------------------------------------------------------
DLQ_DIR=data/dlq
DLQ_MAX_RETRIES=3
RETRY_BACKOFF_BASE_S=0.5


# -----------------------------------------------------------------------------
# ALERTS
# Set to a Slack/Teams/PagerDuty webhook URL to receive anomaly alerts
# Leave empty to disable
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# MODEL RELOAD
# How often to reload Isolation Forest models from MongoDB (minutes)
# -----------------------------------------------------------------------------
MODEL_RELOAD_INTERVAL_MIN=60


# -----------------------------------------------------------------------------
# LOGGING
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR
# LOG_FORMAT: json (for log aggregators) / text (for human reading)
# UERIS_COMPONENT: component name in log lines (auto-set by docker-compose)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
UERIS_COMPONENT=streaming
